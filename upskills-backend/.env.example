# ─── DATABASE ───────────────────────────────────────────────
# Render Postgres — copy from your Render dashboard > PostgreSQL > Connection String
DATABASE_URL=postgresql://user:password@host/upskills_db

# ─── AUTH ────────────────────────────────────────────────────
# Any long random string — used to sign JWT tokens
JWT_SECRET=change_me_to_something_long_and_random_like_this_abc123xyz

# ─── EMAIL (Gmail) ───────────────────────────────────────────
# Use a Gmail account + App Password (NOT your real password)
# Guide: myaccount.google.com > Security > 2FA > App Passwords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# ─── ADMIN ───────────────────────────────────────────────────
# Default admin credentials (change after first login!)
ADMIN_EMAIL=admin@upskills.ph
ADMIN_PASSWORD=UpSkillsAdmin2026!

# ─── APP ─────────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=https://your-frontend-url.com
